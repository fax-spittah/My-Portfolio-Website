---
import { Icon } from "astro-icon/components";

interface Props {
  projectTitle: string;
  projectDescription: string;
  projectLink?: string;
  projectIcon: string;
}

const { projectTitle, projectDescription, projectLink, projectIcon }: Props =
  Astro.props;
---

<div
  class="max-w-sm p-6 bg-white border border-gray-200 rounded-xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 dark:bg-gray-800 dark:border-gray-700"
>
  <Icon
    name={projectIcon}
    class="w-7 h-7 text-blue-600 dark:text-blue-400 mb-3"
  />
  <a href="#">
    <h5
      class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white hover:text-blue-600 transition-colors"
    >
      {projectTitle}
    </h5>
  </a>

  <p class="mb-3 font-normal text-gray-500 dark:text-gray-400">
    {projectDescription}
  </p>
  <a
    href="#"
    class="inline-flex font-semibold items-center text-blue-600 hover:text-blue-800 transition-colors"
  >
    Learn More
    <svg
      class="w-3 h-3 ms-2.5 rtl:rotate-[270deg]"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 18 18"
    >
      <path
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 11v4.833A1.166 1.166 0 0 1 13.833 17H2.167A1.167 1.167 0 0 1 1 15.833V4.167A1.166 1.166 0 0 1 2.167 3h4.618m4.447-2H17v5.768M9.111 8.889l7.778-7.778"
      ></path>
    </svg>
  </a>
</div>
